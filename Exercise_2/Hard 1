#include <stdio.h>
#include <string.h>

int main()
{
    char data[100], stuffed[200], received[200], destuffed[200];
    int i, j = 0, count = 0, errorPos;

    printf("Enter original bit stream: ");
    scanf("%s", data);

    // Bit Stuffing
    for(i = 0; data[i] != '\0'; i++)
    {
        stuffed[j++] = data[i];

        if(data[i] == '1')
        {
            count++;
            if(count == 5)
            {
                stuffed[j++] = '0';
                count = 0;
            }
        }
        else
        {
            count = 0;
        }
    }
    stuffed[j] = '\0';

    printf("\nOriginal Data : %s", data);
    printf("\nStuffed Frame : %s", stuffed);

    // Transmission
    strcpy(received, stuffed);

    printf("\nEnter error position (0 for no error): ");
    scanf("%d", &errorPos);

    if(errorPos > 0)
    {
        if(received[errorPos - 1] == '1')
            received[errorPos - 1] = '0';
        else
            received[errorPos - 1] = '1';
    }

    printf("\nTransmitted Frame : %s", stuffed);
    printf("\nReceived Frame : %s", received);

    if(strcmp(stuffed, received) == 0)
        printf("\nError Status : No Error");
    else
        printf("\nError Status : Error Detected");

    // De-stuffing
    count = 0;
    j = 0;

    for(i = 0; received[i] != '\0'; i++)
    {
        if(received[i] == '1')
        {
            count++;
            destuffed[j++] = received[i];

            if(count == 5)
            {
                i++;
                count = 0;
            }
        }
        else
        {
            count = 0;
            destuffed[j++] = received[i];
        }
    }

    destuffed[j] = '\0';

    printf("\nDe-stuffed Data : %s\n", destuffed);

    return 0;
}
