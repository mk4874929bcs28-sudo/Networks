#include <stdlib.h>

int findMaximumXOR(int* nums, int numsSize) {
    int maxResult = 0;
    int mask = 0;

    for (int i = 30; i >= 0; i--) {
        mask |= (1 << i);
        
        int prefixesSize = 0;
        int* prefixes = (int*)malloc(numsSize * sizeof(int));

        for (int j = 0; j < numsSize; j++) {
            int currentPrefix = nums[j] & mask;
            int isDuplicate = 0;
            for (int k = 0; k < prefixesSize; k++) {
                if (prefixes[k] == currentPrefix) {
                    isDuplicate = 1;
                    break;
                }
            }
            if (!isDuplicate) {
                prefixes[prefixesSize++] = currentPrefix;
            }
        }

        int potentialMax = maxResult | (1 << i);
        for (int j = 0; j < prefixesSize; j++) {
            int complement = potentialMax ^ prefixes[j];
            int found = 0;
            for (int k = 0; k < prefixesSize; k++) {
                if (prefixes[k] == complement) {
                    found = 1;
                    break;
                }
            }
            if (found) {
                maxResult = potentialMax;
                break;
            }
        }

        free(prefixes);
    }

    return maxResult;
}
